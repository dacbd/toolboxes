set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

dir := justfile_directory()
image := env_var_or_default("AGENTS_IMAGE", "agents")
tag := env_var_or_default("AGENTS_TAG", "local")
platforms := env_var_or_default("PLATFORMS", "linux/amd64,linux/arm64")
oci_archive := env_var_or_default("AGENTS_OCI_ARCHIVE", dir + "/../dist/agents.tar")
ghcr_image := env_var_or_default("AGENTS_GHCR_IMAGE", "ghcr.io/dacbd/toolboxes/agents")
push_tag := env_var_or_default("AGENTS_PUSH_TAG", "latest")

default:
    @just --justfile "{{dir}}/justfile" --list

# Build the agents image for the current host architecture.
build-local:
    docker build -t "{{image}}:{{tag}}" -f "{{dir}}/Dockerfile" "{{dir}}"

# Verify expected agents image tools are present.
smoke:
    docker run --rm "{{image}}:{{tag}}" bash -lc 'set -euo pipefail; for c in opencode node npm go rustc cargo git gh curl jq rg fd python3; do command -v "$c" >/dev/null || { echo "missing $c"; exit 1; }; done; opencode --version; node --version; go version; rustc --version; cargo --version'

# Build the agents multi-platform OCI image archive for amd64 and arm64.
build:
    mkdir -p "$(dirname "{{oci_archive}}")"
    docker buildx build --platform "{{platforms}}" -t "{{image}}:{{tag}}" -f "{{dir}}/Dockerfile" --provenance=false --output "type=oci,dest={{oci_archive}}" "{{dir}}"

# Validate the agents Dockerfile and GHCR image reference without pushing.
check:
    docker buildx build --check --platform "{{platforms}}" -t "{{ghcr_image}}:{{push_tag}}" -f "{{dir}}/Dockerfile" "{{dir}}"

# Push the agents multi-platform image to GHCR for this repository.
push:
    docker buildx build --platform "{{platforms}}" -t "{{ghcr_image}}:{{push_tag}}" -f "{{dir}}/Dockerfile" --provenance=false --push "{{dir}}"

# Build and load a single-platform amd64 agents image into the local Docker image store.
build-amd64:
    docker buildx build --platform linux/amd64 -t "{{image}}:{{tag}}-amd64" -f "{{dir}}/Dockerfile" --provenance=false --load "{{dir}}"

# Build and load a single-platform arm64 agents image into the local Docker image store.
build-arm64:
    docker buildx build --platform linux/arm64 -t "{{image}}:{{tag}}-arm64" -f "{{dir}}/Dockerfile" --provenance=false --load "{{dir}}"
